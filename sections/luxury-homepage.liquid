{% stylesheet %}
.luxury-section {
  background: #050505;
  color: #fff;
  padding: 80px 20px;
}

.luxury-container {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}

/* HERO */
.luxury-hero {
  min-height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: #050505;
  position: relative;
}

.luxury-hero h1 {
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-family: serif;
  margin-bottom: 20px;
}

.luxury-hero p {
  max-width: 700px;
  opacity: 0.85;
  font-size: 1.1rem;
  line-height: 1.6;
}

.luxury-btn {
  margin-top: 20px;
  padding: 14px 30px;
  border: 1px solid #C8A76A;
  color: #C8A76A;
  text-transform: uppercase;
  letter-spacing: 2px;
  text-decoration: none;
  display: inline-block;
  transition: 0.3s ease;
}

.luxury-btn:hover {
  background: #C8A76A;
  color: #000;
}

/* TRUST BAR */
.trust-bar {
  margin-top: 40px;
  font-size: 0.9rem;
  opacity: 0.8;
}

/* SECTION HEADINGS */
.section-title {
  font-size: 2.5rem;
  margin-bottom: 20px;
  font-family: serif;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
  margin-top: 40px;
}

.card {
  background: #0d0d0d;
  border: 1px solid rgba(200,167,106,0.25);
  padding: 20px;
  border-radius: 12px;
  transition: 0.3s ease;
}

.card:hover {
  transform: translateY(-5px);
  border-color: #C8A76A;
}

/* GOLD TEXT */
.gold {
  color: #C8A76A;
}
{% endstylesheet %}

<div class="luxury-section">

  <!-- HERO -->
  <div class="luxury-hero">
    <h1>{{ section.settings.hero_title }}</h1>
    <p>{{ section.settings.hero_text }}</p>

    <a href="{{ section.settings.hero_button_link }}" class="luxury-btn">
      {{ section.settings.hero_button }}
    </a>

    <div class="trust-bar">
      ★★★★★ Trusted By Thousands • Extrait de Parfum • Free UK Shipping Over £50
    </div>
  </div>

  <!-- DIFFERENCE -->
  <div class="luxury-container">
    <h2 class="section-title">{{ section.settings.section2_title }}</h2>
    <p>{{ section.settings.section2_text }}</p>
  </div>

  <!-- BEST SELLERS -->
  <div class="luxury-container">
    <h2 class="section-title">Most Wanted</h2>

    <div class="grid">
      <div class="card">
        <h3>Ombre Oud</h3>
        <p>Dark • Smoky • Powerful</p>
      </div>

      <div class="card">
        <h3>Imagine</h3>
        <p>Fresh • Bright • Sophisticated</p>
      </div>

      <div class="card">
        <h3>Amber</h3>
        <p>Warm • Elegant • Addictive</p>
      </div>

      <div class="card">
        <h3>Angel</h3>
        <p>Sweet • Rich • Seductive</p>
      </div>
    </div>
  </div>

  <!-- BRAND STORY -->
  <div class="luxury-container" style="margin-top:80px;">
    <h2 class="section-title">Crafted For Fragrance Lovers</h2>
    <p>
      Luxury fragrance should be judged by its scent, not its price tag.
      We use premium oils and Extrait concentrations to create long-lasting,
      high-performance fragrances inspired by iconic scents.
    </p>

    <a href="/collections/all" class="luxury-btn">Explore All Fragrances</a>
  </div>

</div>

{% schema %}
{
  "name": "Luxury Homepage",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Luxury Without The Markup"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Hero Text",
      "default": "Experience Extrait de Parfum crafted for exceptional longevity, projection and sophistication."
    },
    {
      "type": "text",
      "id": "hero_button",
      "label": "Hero Button Text",
      "default": "Shop Best Sellers"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Hero Button Link"
    },
    {
      "type": "text",
      "id": "section2_title",
      "label": "Section 2 Title",
      "default": "The Difference Is In The Formula"
    },
    {
      "type": "textarea",
      "id": "section2_text",
      "label": "Section 2 Text",
      "default": "Premium oils. Extrait concentration. Long-lasting performance."
    }
  ],
  "presets": [
    {
      "name": "Luxury Homepage"
    }
  ]
}
{% endschema %}